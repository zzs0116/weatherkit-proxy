{
    "name": "@meme/weatherkit-proxy",
    "type": "module",
    "organizationName": "meme",
    "displayName": "WeatherKit-Proxy",
    "description": "iOS 18 & macOS 15 & watchOS 11\n1. 解锁全部天气功能\n2. 替换空气质量数据\n3. 添加下一小时降水数据\n4. 支持 Cloudflare Workers 独立自托管部署与代理配置一键动态下载",
    "homepage": "https://github.com/meme-lau/weatherkit-proxy",
    "openUrl": "https://github.com/meme-lau/weatherkit-proxy",
    "icon": "https://developer.apple.com/assets/elements/icons/weatherkit/weatherkit-128x128.png",
    "keywords": [],
    "contributors": [
        "meme[https://github.com/meme]"
    ],
    "system": [
        "iOS",
        "iPadOS",
        "macOS",
        "watchOS"
    ],
    "systemVersion": 18,
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/meme-lau/weatherkit-proxy.git"
    },
    "directories": {
        "example": "example"
    },
    "scripts": {
        "dev": "npm run dev:wrangler",
        "dev:vercel": "npx -y vercel dev",
        "dev:wrangler": "node ./node_modules/wrangler/bin/wrangler.js dev",
        "deploy:vercel": "npx vercel deploy --prod",
        "deploy:wrangler": "node ./node_modules/wrangler/bin/wrangler.js deploy --minify",
        "build": "echo 'No build step required'",
        "test": "node --test",
        "submodule": "git submodule update --remote",
        "update": "npm update --save"
    },
    "browserslist": [
        "iOS >= 18"
    ],
    "devDependencies": {
        "@biomejs/biome": "2.1.4",
        "typescript": "^5.9.3",
        "wrangler": "^3.109.0"
    },
    "dependencies": {
        "fetch-cookie": "^3.2.0",
        "flatbuffers": "^24.12.23",
        "hono": "^4.12.5",
        "node-fetch": "^3.3.2",
        "node-polyfill-webpack-plugin": "^4.1.0"
    }
}
